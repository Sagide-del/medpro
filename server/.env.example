# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ---- Database ----
DATABASE_URL=postgres://medpro:medpro@localhost:5432/medpro
# Set DB_SSL=true to connect over TLS — required by managed Postgres
# (Railway, Render, Supabase, Neon). Leave false for a self-hosted/
# docker-compose Postgres container, which has no TLS listener at all.
DB_SSL=false
# Most managed providers use a certificate chain Node won't validate by
# default, so this defaults to false; set to "true" only if your provider
# gives you a verifiable cert.
DB_SSL_REJECT_UNAUTHORIZED=false

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# ---- M-Pesa Daraja (Safaricom) ----
# Leave the placeholders below to run in local dev — purchases auto-complete
# without a real Daraja account. Fill in real sandbox/production values to
# exercise the live STK Push flow.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/payments/mpesa/callback

# ---- IntaSend student subscriptions ----
# Leave placeholders in local development to simulate a successful checkout
# through the existing Stage 11 subscription flow.
INTASEND_PUBLIC_KEY=your_intasend_public_key
INTASEND_SECRET_KEY=your_intasend_secret_key
INTASEND_WEBHOOK_SECRET=your_intasend_webhook_secret
INTASEND_BASE_URL=https://sandbox.intasend.com/api/v1
INTASEND_REDIRECT_URL=http://localhost:5173/student/subscription
INTASEND_WEBHOOK_URL=http://localhost:5000/api/payments/intasend/webhook
INTASEND_HOST_URL=http://localhost:5173

# ---- SMS (Africa's Talking) / WhatsApp (Meta Cloud API) ----
# Same pattern as M-Pesa: leave as placeholders to simulate group alert
# sends locally. Fill in real credentials to send actual SMS/WhatsApp.
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# ---- File storage (worksheets, videos, graphics, elibrary, logbook, research uploads) ----
# Leave AWS_S3_BUCKET unset to store uploads on local disk (server/uploads/) —
# fine for local dev, but wiped on every redeploy on Railway/most PaaS. Set
# these to switch to S3; credentials are picked up from the standard
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars (the AWS SDK reads them
# automatically, no code changes needed).
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: a CloudFront/custom domain in front of the bucket. Leave unset to
# use the bucket's own regional S3 URL.
AWS_S3_PUBLIC_URL=

# ---- Logging ----
LOG_LEVEL=info
